# Supabase project (find at https://supabase.com/dashboard/project/<id>/settings/api)
SUPABASE_URL=https://your-project-ref.supabase.co
SUPABASE_ANON_KEY=your-anon-key
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# OpenAI (used by the embed script and the semantic-search Edge Function)
OPENAI_API_KEY=sk-...

# Optional: path to the FAQ CSV (defaults to ../smart-faq.csv relative to repo root)
FAQ_CSV_PATH=../smart-faq.csv
