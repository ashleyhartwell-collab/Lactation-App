# Copy this file to .env.test and fill in your real values.
# .env.test is gitignored — never commit real keys.
#
# WHERE TO FIND THESE VALUES
# ---------------------------
# Supabase dashboard → your project → Settings → API
#   SUPABASE_URL              = Project URL
#   SUPABASE_ANON_KEY         = anon / public key
#   SUPABASE_SERVICE_ROLE_KEY = service_role key  ← keep secret, admin access

# Live app URL — Lovable publish URL (or http://localhost:5173 for local dev)
# Must match the APP_URL key that playwright.config.ts reads
APP_URL=https://mama-milk-map.lovable.app

# Supabase project URL
SUPABASE_URL=https://owxrfpqyjsevwkbythrw.supabase.co

# Service role key — required for global-setup to create/delete test users via admin API
SUPABASE_SERVICE_ROLE_KEY=your_service_role_key_here

# Anon (public) key — used by global-setup to verify sign-in works end-to-end
SUPABASE_ANON_KEY=your_anon_key_here
